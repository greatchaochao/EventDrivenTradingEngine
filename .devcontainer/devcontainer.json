{
  "image": "mcr.microsoft.com/devcontainers/cpp:latest",
  // postCreateCommand 在 Codespace 首次创建后自动执行一次
  // 第一步：用 apt-get 安装 python3-pip（容器自带 Python 但没有 pip）
  // 第二步：用 pip 安装绘图依赖
  // 这比安装整个 pyenv/Python feature 快得多（几秒 vs 几分钟）
  "postCreateCommand": "apt-get install -y python3-pip --quiet && python3 -m pip install pandas matplotlib --quiet --break-system-packages",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cmake-tools"
      ]
    }
  }
}