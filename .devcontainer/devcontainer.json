{
  "image": "mcr.microsoft.com/devcontainers/cpp:latest",
  // postCreateCommand 在 Codespace 首次创建后自动执行一次
  // ensurepip 是 Python 内置模块，无需 apt 即可为当前解释器安装 pip
  // 完全不依赖系统包管理器，速度快且不受 apt 源限制
  "postCreateCommand": "python3 -m ensurepip --upgrade && python3 -m pip install pandas matplotlib --quiet --break-system-packages",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cmake-tools"
      ]
    }
  }
}